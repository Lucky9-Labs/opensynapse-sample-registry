{
  "schemaVersion": 1,
  "managedSettings": {
    "managedMcpServers": [
      {
        "name": "opensynapse",
        "transport": "http",
        "url": "${OPENSYNAPSE_MCP_URL}",
        "oauth": {
          "mode": "byo",
          "clientId": "${OPENSYNAPSE_MCP_OAUTH_CLIENT_ID}",
          "authorizationServer": "${OPENSYNAPSE_MCP_OAUTH_ISSUER}",
          "scope": "${OPENSYNAPSE_MCP_OAUTH_SCOPES}",
          "callbackHost": "127.0.0.1",
          "callbackPort": "${OPENSYNAPSE_MCP_OAUTH_CALLBACK_PORT}"
        },
        "toolPolicy": {
          "*": "ask"
        }
      }
    ],
    "extraKnownMarketplaces": {
      "opensynapse-sample-registry": {
        "source": {
          "source": "github",
          "repo": "Lucky9-Labs/opensynapse-sample-registry",
          "ref": "${EXTENSION_REGISTRY_REF}"
        }
      }
    },
    "strictKnownMarketplaces": [
      {
        "source": "github",
        "repo": "Lucky9-Labs/opensynapse-sample-registry",
        "ref": "${EXTENSION_REGISTRY_REF}"
      }
    ],
    "enabledPlugins": {
      "opensynapse-sample@opensynapse-sample-registry": true
    }
  }
}
